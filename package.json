{
  "name": "@marcolino/semantic-release-godot",
  "version": "1.0.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "semantic-release plugin to automate version and build code injection for Godot 4 projects.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "examples",
    "README.md"
  ],
  "engines": {
    "node": ">=20",
    "bun": ">=1.2"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm install --no-audit --no-fund && npm run build",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src tests",
    "lint:fix": "biome check --write src tests",
    "format": "biome format --write src tests",
    "format:check": "biome format src tests",
    "test": "bun test tests",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "test:coverage": "bun test tests --coverage",
    "audit": "bun audit"
  },
  "peerDependencies": {
    "semantic-release": ">=24"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^20.0.0",
    "semantic-release": "24.2.0",
    "typescript": "^5.6.0"
  }
}
